# Dependencies (rebuilt in container)
node_modules
vendor

# Git and IDE
.git
.gitignore
.cursor
.claude
.idea
.vscode

# Env and secrets (keep .env.example for reference)
.env
.env.backup
.env.production
.env.production.vps

# Build artifacts (Vite will rebuild)
public/build
public/hot

# Tests and dev
tests
phpunit.xml
.phpunit.cache
.phpunit.result.cache

# Logs and cache
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*
!storage/logs/.gitkeep
!storage/framework/cache/.gitkeep
!storage/framework/sessions/.gitkeep
!storage/framework/views/.gitkeep
!bootstrap/cache/.gitkeep

# Deploy (host-only, must not run inside container)
deploy.sh
deploy-swarm.sh

# Debug logs
debug-*.log

# Misc
*.md
Dockerfile
docker-compose*.yml
.dockerignore
