APP_NAME="Tenaz CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.tenazcrm.com.br
ASSET_URL=https://app.tenazcrm.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
APP_PREVIOUS_KEYS=

BCRYPT_ROUNDS=12

# Build/version introspection. Prefer filling these at deploy time.
APP_BUILD_SHA=
APP_BUILD_TAG=
APP_BUILD_TIME=
APP_VERSION_TOKEN=
TENAZ_ADMIN_EMAILS=
CREDFLOW_ADMIN_EMAILS=

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# Database
DB_CONNECTION=sqlite
# For PostgreSQL/MySQL in production, set these in the real .env:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=tenaz_crm
# DB_USERNAME=tenaz_crm
# DB_PASSWORD=

# Session / Cache / Queue
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_RETRY_AFTER=3900

# Mail
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="tenaz@seudominio.com.br"
MAIL_FROM_NAME="Tenaz CRM"
RESEND_API_KEY=
POSTMARK_API_KEY=

# SMTP alternative:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailprovider.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# AI providers
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
VOYAGEAI_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_URL=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Tenaz CRM API and agent webhooks
TENAZ_WEBHOOK_CONSULTA=https://n8n.seudominio.com.br/webhook/consulta-credito
TENAZ_WEBHOOK_CONSULTA_SIAPE=
TENAZ_WEBHOOK_ESCALAR=https://n8n.seudominio.com.br/webhook/escalar
TENAZ_WEBHOOK_REGISTRAR=https://n8n.seudominio.com.br/webhook/registrar-sem-margem
TENAZ_API_KEY=
TENAZ_DEFAULT_TENANT_ID=default
# Multi-tenant keys: "key1:tenant_a,key2:tenant_b".
TENAZ_API_KEYS=

# Legacy aliases still read by config/services.php and config/credflow.php.
CREDFLOW_WEBHOOK_CONSULTA=
CREDFLOW_WEBHOOK_CONSULTA_SIAPE=
CREDFLOW_WEBHOOK_ESCALAR=
CREDFLOW_WEBHOOK_REGISTRAR=
CREDFLOW_API_KEY=
ARIA_WEBHOOK_CONSULTA=
ARIA_WEBHOOK_CONSULTA_SIAPE=
ARIA_WEBHOOK_ESCALAR=
ARIA_WEBHOOK_REGISTRAR=
ARIA_API_KEY=

# External credit provider
PROMOSYS_BASE_URL=https://jcf.promosysweb.com/services
PROMOSYS_USUARIO=
PROMOSYS_SENHA=

# Agent runtime defaults
DEBOUNCE_SECONDS=3
TENAZ_AGENT_FALLBACK_PROVIDER=openrouter
TENAZ_AGENT_FALLBACK_MODEL=anthropic/claude-haiku-4-5
TENAZ_AGENT_MAX_MESSAGES=24
TENAZ_AGENT_TEMPERATURE=0.4
TENAZ_AGENT_MAX_TOKENS=1024
TENAZ_AGENT_MAX_STEPS=10
TENAZ_AGENT_MAX_TOTAL_STEPS=12
TENAZ_AGENT_TIMEOUT_SECONDS=45
TENAZ_AGENT_ARCHITECTURE_VERSION=legacy_prompt
TENAZ_AGENT_FAILOVER_ENABLED=false
TENAZ_AGENT_FAILOVER_PROVIDER=
TENAZ_AGENT_FAILOVER_MODEL=
TENAZ_TOKEN_WARNING_PROMPT=3000
TENAZ_TOKEN_WARNING_TOTAL=4000

# Legacy agent aliases.
CREDFLOW_AGENT_FALLBACK_PROVIDER=openrouter
CREDFLOW_AGENT_FALLBACK_MODEL=anthropic/claude-haiku-4-5
CREDFLOW_AGENT_MAX_MESSAGES=24
CREDFLOW_AGENT_TEMPERATURE=0.4
CREDFLOW_AGENT_MAX_TOKENS=1024
CREDFLOW_AGENT_MAX_STEPS=10
CREDFLOW_AGENT_MAX_TOTAL_STEPS=12
CREDFLOW_AGENT_TIMEOUT_SECONDS=45
CREDFLOW_AGENT_ARCHITECTURE_VERSION=legacy_prompt
CREDFLOW_TOKEN_WARNING_PROMPT=3000
CREDFLOW_TOKEN_WARNING_TOTAL=4000

# Follow-up
FOLLOWUP_FIRST_DELAY_MINUTES=10
FOLLOWUP_DAILY_TIME=10:00
FOLLOWUP_MAX_COUNT=4
FOLLOWUP_SKIP_IF_RECENT_INBOUND_MINUTES=30

# API / circuit breaker
TENAZ_CIRCUIT_BREAKER_THRESHOLD=5
TENAZ_CIRCUIT_BREAKER_WINDOW=5
TENAZ_API_RATE_LIMIT=120
TENAZ_RATE_LIMIT_PER_PHONE=30
TENAZ_URA_KEY_LAST_USED_DEBOUNCE_SECONDS=300
CREDFLOW_CIRCUIT_BREAKER_THRESHOLD=5
CREDFLOW_CIRCUIT_BREAKER_WINDOW=5
CREDFLOW_API_RATE_LIMIT=120
CREDFLOW_RATE_LIMIT_PER_PHONE=30
CREDFLOW_URA_KEY_LAST_USED_DEBOUNCE_SECONDS=300

# Campaign runtime and SCALE controls
TENAZ_CAMPAIGN_RATE_PER_MINUTE=80
TENAZ_CAMPAIGN_RATE_LIMIT_RELEASE=60
TENAZ_CAMPAIGN_AUTOPAUSE_DEBOUNCE=3
TENAZ_CAMPAIGN_TENANT_RATE_PER_MINUTE=0
TENAZ_CAMPAIGN_SEND_RETRY_WINDOW=21600
TENAZ_CAMPAIGN_SEND_CONFIG_CACHE=300
TENAZ_CAMPAIGN_DISPATCH_MAX_REDISPATCH=2
TENAZ_CAMPAIGN_DISPATCH_REDISPATCH_DELAY=10
TENAZ_CRON_DISPATCH_JITTER_SECONDS=240

# Legacy campaign aliases.
CREDFLOW_CAMPAIGN_RATE_PER_MINUTE=80
CREDFLOW_CAMPAIGN_RATE_LIMIT_RELEASE=60
CREDFLOW_CAMPAIGN_AUTOPAUSE_DEBOUNCE=3
CREDFLOW_CAMPAIGN_TENANT_RATE_PER_MINUTE=0
CREDFLOW_CAMPAIGN_SEND_RETRY_WINDOW=21600
CREDFLOW_CAMPAIGN_SEND_CONFIG_CACHE=300
CREDFLOW_CAMPAIGN_DISPATCH_MAX_REDISPATCH=2
CREDFLOW_CAMPAIGN_DISPATCH_REDISPATCH_DELAY=10
CREDFLOW_CRON_DISPATCH_JITTER_SECONDS=240

# Job retry windows
TENAZ_AUTO_TAG_RETRY_WINDOW_SECONDS=1800
TENAZ_INCOMING_MESSAGE_RETRY_WINDOW_SECONDS=1800
TENAZ_OUTBOX_RETRY_WINDOW_SECONDS=21600
TENAZ_TEMPLATE_SYNC_RETRY_WINDOW_SECONDS=3600
TENAZ_TEMPLATE_SYNC_MAX_RETRY_AFTER_SECONDS=3600
CREDFLOW_AUTO_TAG_RETRY_WINDOW_SECONDS=1800
CREDFLOW_INCOMING_MESSAGE_RETRY_WINDOW_SECONDS=1800
CREDFLOW_OUTBOX_RETRY_WINDOW_SECONDS=21600
CREDFLOW_TEMPLATE_SYNC_RETRY_WINDOW_SECONDS=3600
CREDFLOW_TEMPLATE_SYNC_MAX_RETRY_AFTER_SECONDS=3600

# Seeder only
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Reverb / WebSocket
REVERB_APP_ID=tenaz-crm
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# Laboratory / Langfuse / alerts
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_DASHBOARD_URL=
ALERT_ENABLED=false
ALERT_CHANNEL=slack
SLACK_ALERT_WEBHOOK_URL=
STRESS_TEST_TIMEOUT=3600
TENAZ_DAILY_COST_ALERT_USD=10
CREDFLOW_DAILY_COST_ALERT_USD=10

# Meta Cloud API (WhatsApp Cloud API)
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
META_APP_CONFIG_ID=
META_APP_CONFIG_ID_COEXISTENCE=
META_GRAPH_API_VERSION=v23.0

# Twilio / URA / Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
URA_API_KEY=
GOOGLE_TTS_API_KEY=

VITE_APP_NAME="${APP_NAME}"
