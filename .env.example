APP_NAME="Tenaz CRM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://app.tenazcrm.com.br

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR
APP_TIMEZONE=America/Sao_Paulo

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=sqlite
# Para PostgreSQL/MySQL em produção:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1   ← use 127.0.0.1 ou IP do servidor; "postgres_postgres" só resolve dentro da rede Docker
# DB_PORT=5432
# DB_DATABASE=tenaz_crm
# DB_USERNAME=tenaz_crm
# DB_PASSWORD=

# ─── Session / Cache / Queue ─────────────────────────────────────────────────
# Use redis em produção. Horizon já assume connection=redis.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

# ─── Mail ────────────────────────────────────────────────────────────────────
# Necessário para reset de senha. Use Resend, Postmark, SES ou SMTP.
MAIL_MAILER=resend
MAIL_FROM_ADDRESS="tenaz@seudominio.com.br"
MAIL_FROM_NAME="Tenaz CRM"
RESEND_API_KEY=

# Alternativa SMTP:
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mailprovider.com
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_ENCRYPTION=tls

# ─── AI (OpenAI) ─────────────────────────────────────────────────────────────
# Chave OpenAI — obrigatório para o agente funcionar.
OPENAI_API_KEY=sk-...

# Opcional: OpenRouter como alternativa ao OpenAI
OPENROUTER_API_KEY=

# ─── Tenaz CRM Webhooks (Ferramentas do Agente) ────────────────────────────────
# Webhook chamado pelo agente para consultar crédito INSS
TENAZ_WEBHOOK_CONSULTA=https://n8n.seudominio.com.br/webhook/consulta-credito
CREDFLOW_WEBHOOK_CONSULTA=
TENAZ_WEBHOOK_CONSULTA_SIAPE=
CREDFLOW_WEBHOOK_CONSULTA_SIAPE=
# Webhook para escalar atendimento para humano
TENAZ_WEBHOOK_ESCALAR=https://n8n.seudominio.com.br/webhook/escalar
CREDFLOW_WEBHOOK_ESCALAR=
# Webhook para registrar lead sem margem
TENAZ_WEBHOOK_REGISTRAR=https://n8n.seudominio.com.br/webhook/registrar-sem-margem
CREDFLOW_WEBHOOK_REGISTRAR=
# API key usada pelo agente ao chamar /api/tenaz diretamente (n8n, integrações).
# Esta chave fica vinculada ao tenant abaixo (TENAZ_DEFAULT_TENANT_ID).
TENAZ_API_KEY=
CREDFLOW_API_KEY=
# Tenant atribuído à TENAZ_API_KEY legada. O tenant_id passado no payload é
# validado contra a chave: se não bater, a requisição é rejeitada (403).
TENAZ_DEFAULT_TENANT_ID=default
# Chaves por tenant (multi-tenant): "chave1:tenant_a,chave2:tenant_b".
# Cada chave só pode operar sobre o seu próprio tenant_id.
TENAZ_API_KEYS=

PROMOSYS_BASE_URL=https://jcf.promosysweb.com/services
PROMOSYS_USUARIO=
PROMOSYS_SENHA=

# ─── Configurações do Agente (override via interface /agente) ─────────────────
# Estes valores servem como fallback global; cada usuário pode customizar na UI.
DEBOUNCE_SECONDS=3
TENAZ_AGENT_MAX_MESSAGES=24
TENAZ_AGENT_TEMPERATURE=0.4
TENAZ_AGENT_MAX_TOKENS=1024
TENAZ_AGENT_MAX_STEPS=10
TENAZ_AGENT_MAX_TOTAL_STEPS=12
TENAZ_AGENT_TIMEOUT_SECONDS=45

# ─── Follow-up (override via interface /agente/follow-up) ─────────────────────
FOLLOWUP_FIRST_DELAY_MINUTES=10
FOLLOWUP_DAILY_TIME=10:00
FOLLOWUP_MAX_COUNT=4

# ─── Circuit Breaker ─────────────────────────────────────────────────────────
TENAZ_CIRCUIT_BREAKER_THRESHOLD=5
TENAZ_CIRCUIT_BREAKER_WINDOW=5
TENAZ_API_RATE_LIMIT=120

# ─── Seeder (apenas para php artisan db:seed) ─────────────────────────────────
# Preencha para criar o primeiro usuário admin via seeder.
# Alternativa: php artisan credflow:create-user
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# ─── AWS (opcional, se usar S3 para storage) ──────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Reverb (WebSocket) ───────────────────────────────────────────────────────
# Gere chaves aleatórias: openssl rand -hex 16
REVERB_APP_ID=tenaz-crm
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

# ─── Laboratory / Langfuse (observabilidade LLM) ─────────────────────────────
# LANGFUSE_HOST = região correta: https://cloud.langfuse.com (EU) ou https://us.cloud.langfuse.com (US)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# URL completa do projeto no Langfuse (botão "Langfuse" no Laboratory). Ex.: https://cloud.langfuse.com/project/abc123/traces
LANGFUSE_DASHBOARD_URL=

# ─── Meta Cloud API (WhatsApp Cloud API) ─────────────────────────────────────
# Criado em developers.facebook.com -> Apps -> Seu App -> Settings -> Basic
META_APP_ID=
META_APP_SECRET=
# String aleatória definida pelo operador (ex: openssl rand -hex 32) — mesmo valor colado no painel Meta
META_WEBHOOK_VERIFY_TOKEN=
# Facebook Login for Business -> Configurations -> Configuration ID (new/migrate)
META_APP_CONFIG_ID=
# Config ID for Coexistence mode (separate FBL config with coexist feature type enabled)
META_APP_CONFIG_ID_COEXISTENCE=
# Versão da Graph API — manter v23.0 (current stable)
META_GRAPH_API_VERSION=v23.0

# ─── Twilio (IVR/URA Voice Channel) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

VITE_APP_NAME="${APP_NAME}"
